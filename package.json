{
  "name": "agentmesh",
  "version": "0.1.0",
  "private": true,
  "description": "Decentralized marketplace where AI tool providers register MCP tools, orchestrated via P2P mesh with crypto-native payments and reputation tracking.",
  "workspaces": [
    "packages/*",
    "client"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "dev:client": "bun run --filter client dev",
    "dev:orchestrator": "bun run --filter @agentmesh/orchestrator dev",
    "dev:researcher": "bun run --filter @agentmesh/researcher dev",
    "dev:risk-analyst": "bun run --filter @agentmesh/risk-analyst dev",
    "dev:executor": "bun run --filter @agentmesh/executor dev",
    "contracts:compile": "bun run --filter @agentmesh/contracts compile",
    "contracts:test": "bun run --filter @agentmesh/contracts test",
    "contracts:deploy": "bun run --filter @agentmesh/contracts deploy"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "bun@1.2.0"
}
