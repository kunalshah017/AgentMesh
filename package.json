{
  "name": "agentmesh",
  "version": "0.1.0",
  "private": true,
  "description": "Decentralized marketplace where AI tool providers register MCP tools, orchestrated via P2P mesh with crypto-native payments and reputation tracking.",
  "workspaces": [
    "packages/*",
    "client"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "dev:client": "npm run dev --workspace=client",
    "dev:orchestrator": "npm run dev --workspace=@agentmesh/orchestrator",
    "dev:researcher": "npm run dev --workspace=@agentmesh/researcher",
    "dev:risk-analyst": "npm run dev --workspace=@agentmesh/risk-analyst",
    "dev:executor": "npm run dev --workspace=@agentmesh/executor",
    "contracts:compile": "npm run compile --workspace=@agentmesh/contracts",
    "contracts:test": "npm run test --workspace=@agentmesh/contracts",
    "contracts:deploy": "npm run deploy --workspace=@agentmesh/contracts"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.0"
}
