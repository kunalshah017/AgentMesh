{
  "name": "@agentmesh/researcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./tools": {
      "bun": "./src/tools/index.ts",
      "default": "./dist/tools/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentmesh/shared": "*",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/bun": "latest",
    "@types/express": "^5.0.0"
  }
}
