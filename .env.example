# ============================================
# AgentMesh Environment Configuration
# Copy to .env and fill in values
# ============================================

# --- 0G Compute (LLM Inference) ---
ZG_SERVICE_URL=https://inference-api.0g.ai
ZG_API_SECRET=app-sk-YOUR_KEY_HERE

# --- 0G Storage ---
ZG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# --- 0G Chain ---
ZG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
AGENT_REGISTRY_ADDRESS=0x617eDCC3068774492a20E2B5d23f155e0CCA73Db
REPUTATION_TRACKER_ADDRESS=0xc9EF38Ba33BcFD35b04c8255564473B656F099aB

# --- Wallet (shared signer for testnet) ---
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# --- Uniswap Trading API ---
UNISWAP_API_KEY=YOUR_UNISWAP_API_KEY

# --- KeeperHub ---
KEEPERHUB_API_KEY=YOUR_KEEPERHUB_API_KEY

# --- ENS (Sepolia) ---
ENS_RPC_URL=https://rpc.sepolia.org

# --- AXL Node Ports ---
AXL_ORCHESTRATOR_PORT=9002
AXL_RESEARCHER_PORT=9012
AXL_RISK_ANALYST_PORT=9022
AXL_EXECUTOR_PORT=9032

# --- x402 Payments ---
X402_FACILITATOR_URL=https://facilitator.x402.org
X402_PAYMENT_TOKEN=USDC

# --- Frontend ---
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
